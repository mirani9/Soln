# ─── SENTINEL — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!

# ─── Firebase (Frontend) ────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# ─── Backend ────────────────────────────────────────────────────
# Path to Firebase service account key (default: backend/serviceAccountKey.json)
# FIREBASE_SERVICE_ACCOUNT_PATH=backend/serviceAccountKey.json
# FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Ollama LLM URL (default: http://localhost:11434/api/generate)
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=llama3

# CORS origins (comma-separated, default: * for development)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
